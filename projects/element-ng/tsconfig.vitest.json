{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "../../out-tsc/spec",
    "lib": ["es2024", "dom", "esnext.disposable"],
    "types": [
      "vitest/globals",
      "vitest/browser",
      "node",
      "@siemens/element-translate-ng/localize-types"
    ]
  },
  "exclude": ["**/schematics/**"],
  "include": [
    "a*/**/*.spec.ts",
    "b*/**/*.spec.ts",
    "c*/**/*.spec.ts",
    "d*/**/*.spec.ts",
    "e*/**/*.spec.ts",
    "w*/**/*.spec.ts",
    "x*/**/*.spec.ts",
    "y*/**/*.spec.ts",
    "z*/**/*.spec.ts",
    "**/*.d.ts"
  ]
}
