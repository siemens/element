      "optional": true
    },
    "mermaid": {
      "optional": true
    },
    "katex": {
      "optional": true
    },
    "remark-gfm": {
      "optional": true
    },
    "remark-math": {
      "optional": true
    },
    "remark-parse": {
      "optional": true
    },
    "unified": {
      "optional": true
    }
  }
