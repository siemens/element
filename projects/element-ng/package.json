      "@siemens/maps-ng",
      "@siemens/native-charts-ng"
    ],
    "migrations": "./schematics/migration.json"
  },
  "peerDependencies": {
    "@angular/cdk": "22",
    "@angular/common": "22",
    "@angular/core": "22",
    "@angular/forms": "22",
    "@angular/router": "22",
    "@ngx-formly/bootstrap": "^6.2.2 || ^7.0.1",
    "@ngx-formly/core": "^6.2.2 || ^7.0.1",
    "@siemens/element-icons": "1",
    "@siemens/element-theme": "workspace:*",
    "@siemens/element-translate-ng": "workspace:*",
    "@siemens/ngx-datatable": "22 - 26",
    "ag-grid-community": "^34.3.1 || ^35.0.0 || ^36.0.0",
    "flag-icons": "^7.3.2",
    "google-libphonenumber": "^3.2.40",
    "highlight.js": "^11.11.1",
    "mermaid": "^11.16.0",
    "katex": "^0.17.0",
    "ngx-image-cropper": "^9.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  },
  "peerDependenciesMeta": {
    "@ngx-formly/bootstrap": {
      "optional": true
    },
    "@ngx-formly/core": {
      "optional": true
    },
    "@siemens/ngx-datatable": {
      "optional": true
    },
    "ngx-image-cropper": {
      "optional": true
    },
    "flag-icons": {
      "optional": true
    },
    "google-libphonenumber": {
      "optional": true
