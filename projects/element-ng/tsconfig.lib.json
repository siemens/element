{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "../../out-tsc/lib",
    "declaration": true,
    "inlineSources": true,
    "types": ["@siemens/element-translate-ng/localize-types", "geojson"],
    "paths": {
      "@siemens/element-translate-ng/*": ["dist/@siemens/element-translate-ng/*"],
      "@siemens/map-styles/*": ["dist/@siemens/map-styles/*"]
    }
  },
  "angularCompilerOptions": {
    "fullTemplateTypeCheck": true,
    "skipTemplateCodegen": true,
    "strictMetadataEmit": true,
    "enableResourceInlining": true,
    "compilationMode": "partial"
  },
  "include": ["./**/*.ts"],
  "exclude": ["**/*.spec.ts", "**/test-helpers/", "**/schematics/", "**/testing/", "./docs.ts"]
}
